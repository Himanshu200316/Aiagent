# OpenAI API Key for content generation
OPENAI_API_KEY=your_openai_api_key_here

# Social Media API Keys
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Cerebrus API Configuration
CEREBRUS_API_KEY=your_cerebrus_api_key
CEREBRUS_API_URL=https://api.cerebrus.com

# Application Configuration
SECRET_KEY=your_secret_key_for_jwt_tokens_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration
DATABASE_URL=sqlite:///./data/social_media_agent.db

# Redis Configuration
REDIS_URL=redis://redis:6379

# Scheduling Configuration
DEFAULT_POST_TIME=00:00
TIMEZONE=UTC

# Image Generation Configuration
STABLE_DIFFUSION_MODEL=runwayml/stable-diffusion-v1-5
MAX_IMAGE_SIZE=1024
IMAGE_QUALITY=95