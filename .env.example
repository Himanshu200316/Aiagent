# Environment Configuration
ENVIRONMENT=development
DEBUG=true

# Cerebrus API Configuration
CEREBRUS_API_KEY=your_cerebrus_api_key_here
CEREBRUS_BASE_URL=https://api.cerebrus.com

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Social Media API Keys
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Database Configuration
DATABASE_URL=postgresql://agent:secure_password@postgres:5432/social_media_agent
REDIS_URL=redis://redis:6379

# Storage Configuration
STORAGE_PATH=/app/data
MAX_IMAGE_SIZE=10485760  # 10MB
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif

# Scheduling Configuration
DEFAULT_POST_TIME=00:00  # 12 AM
TIMEZONE=UTC

# Security
SECRET_KEY=your_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here